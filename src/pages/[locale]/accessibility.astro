---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LOCALES, type Locale } from "../../i18n";

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const pages = await getCollection("pages");
const entry = pages.find((p) => p.id === `${locale}/accessibility`);
if (!entry) {
  throw new Error(
    `Missing accessibility page for locale "${locale}" (expected src/content/pages/${locale}/accessibility.md)`,
  );
}

const { Content } = await render(entry);

const lastUpdatedDate = entry.data.last_updated ?? null;
const lastUpdated = lastUpdatedDate
  ? lastUpdatedDate.toLocaleDateString(locale, {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
const lastUpdatedIso = lastUpdatedDate
  ? lastUpdatedDate.toISOString().slice(0, 10)
  : null;
---

<BaseLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description}
>
  <article class="a11y-wrap">
    <h1>{entry.data.title}</h1>
    {
      lastUpdated && lastUpdatedIso && (
        <p class="last-updated">
          <time datetime={lastUpdatedIso}>{lastUpdated}</time>
        </p>
      )
    }
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .a11y-wrap {
    max-width: 44rem;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: 1.875rem;
    line-height: 1.2;
  }

  .last-updated {
    margin: 0 0 1.5rem;
    font-size: 0.9rem;
    color: var(--page-text-muted);
  }

  .prose {
    font-size: 1rem;
    line-height: 1.6;
  }

  .prose :global(h2) {
    margin: 1.75rem 0 0.5rem;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .prose :global(h3) {
    margin: 1.25rem 0 0.5rem;
    font-size: 1.05rem;
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.25rem 0;
  }

  .prose :global(a) {
    font-weight: 500;
  }

  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.9em;
    background: var(--bg-muted);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }
</style>
