---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LOCALES, type Locale } from "../../i18n";

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const pages = await getCollection("pages");
const homeEntry = pages.find((p) => p.id === `${locale}/home`);
if (!homeEntry) {
  throw new Error(
    `Missing home page for locale "${locale}" (expected src/content/pages/${locale}/home.md)`,
  );
}

const { Content } = await render(homeEntry);
---

<BaseLayout
  locale={locale}
  title={homeEntry.data.title}
  description={homeEntry.data.description}
>
  <Content />
</BaseLayout>
