---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LOCALES, t, type Locale } from "../../i18n";
import { REGIONS, RESOURCE_TYPES } from "../../content.config";
import { formatSchedule, formatDate } from "../../lib/format-schedule";

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };

const listings = (await getCollection("listings")).sort((a, b) =>
  a.data.name[locale].localeCompare(b.data.name[locale], locale),
);

// Build-time "today" — staleness drifts between deploys. For v1 (manual
// deploys) that lag is acceptable; once CI redeploys daily the threshold
// stays fresh.
const NINETY_DAYS_MS = 90 * 24 * 60 * 60 * 1000;
const now = Date.now();

const totalCount = listings.length;
---

<BaseLayout locale={locale} title={t(locale, "list.heading")}>
  <h1>{t(locale, "list.heading")}</h1>

  <section class="filters" aria-label={t(locale, "list.filters_label")} data-filters>
    <div class="search-row" data-search-row hidden>
      <label class="search-label" for="listing-search">
        {t(locale, "list.search_label")}
      </label>
      <input
        id="listing-search"
        type="search"
        class="search-input"
        data-search-input
        placeholder={t(locale, "list.search_placeholder")}
        autocomplete="off"
      />
    </div>

    <fieldset class="filter-group">
      <legend>{t(locale, "list.filter_region_legend")}</legend>
      <div class="chip-group" role="group">
        {
          REGIONS.map((r) => (
            <button
              type="button"
              class="chip"
              data-filter="region"
              data-value={r}
              aria-pressed="false"
            >
              {t(locale, `region.${r}`)}
            </button>
          ))
        }
      </div>
    </fieldset>

    <fieldset class="filter-group">
      <legend>{t(locale, "list.filter_type_legend")}</legend>
      <div class="chip-group" role="group">
        {
          RESOURCE_TYPES.map((rt) => (
            <button
              type="button"
              class="chip"
              data-filter="type"
              data-value={rt}
              aria-pressed="false"
            >
              {t(locale, `resource_type.${rt}`)}
            </button>
          ))
        }
      </div>
    </fieldset>

    <div class="filter-footer">
      <button type="button" class="clear-filters" data-clear-filters hidden>
        {t(locale, "list.clear_filters")}
      </button>
      <p class="results-count" aria-live="polite" data-results-count>
        {totalCount}
      </p>
    </div>
  </section>

  <p class="empty-state" hidden data-empty-state>
    {t(locale, "list.empty")}
  </p>

  <ul role="list" class="listings" data-listings>
    {
      listings.map((listing) => {
        const { data } = listing;
        const isStale =
          now - data.last_verified_date.getTime() > NINETY_DAYS_MS;
        const { location } = data;
        const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${location.lat},${location.lng}`;
        const formatted = formatSchedule(data.schedule, locale);
        const addressLine = [
          location.address_1,
          location.address_2,
          `${location.city}, ${location.state} ${location.zip_code}`,
        ]
          .filter(Boolean)
          .join(", ");

        return (
          <li
            class:list={["listing", { "listing-stale": isStale }]}
            data-listing-id={listing.id}
            data-region={data.region}
            data-types={data.resource_type.join(" ")}
          >
            <article aria-labelledby={`listing-${listing.id}-heading`}>
              <header class="listing-header">
                <h2 id={`listing-${listing.id}-heading`}>
                  {data.name[locale]}
                </h2>
                <p class="location-name">{data.location_name[locale]}</p>
              </header>

              <ul role="list" class="tags">
                {data.resource_type.map((rt) => (
                  <li class="tag tag-type">
                    {t(locale, `resource_type.${rt}`)}
                  </li>
                ))}
                {data.category.map((c) => (
                  <li class="tag tag-category">{t(locale, `category.${c}`)}</li>
                ))}
                {data.seasons?.map((s) => (
                  <li class="tag tag-season">{t(locale, `season.${s}`)}</li>
                ))}
              </ul>

              <p class="description">{data.description[locale]}</p>

              <dl class="listing-facts">
                <div class="fact">
                  <dt>{t(locale, "listing.hours_label")}</dt>
                  <dd>
                    {formatted.kind === "text" ? (
                      <span>{formatted.text}</span>
                    ) : (
                      <ul role="list" class="hours-rows">
                        {formatted.rows.map((row) => (
                          <li>
                            <span class="hours-label">{row.label}</span>
                            <span class="hours-time">{row.time}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </dd>
                </div>

                <div class="fact">
                  <dt>{t(locale, "listing.address_label")}</dt>
                  <dd>
                    <a
                      href={mapsUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {addressLine}
                    </a>
                  </dd>
                </div>

                {data.barriers_to_entry && (
                  <div class="fact">
                    <dt>{t(locale, "listing.barriers_to_entry")}</dt>
                    <dd>{data.barriers_to_entry[locale]}</dd>
                  </div>
                )}

                {data.accessibility_notes && (
                  <div class="fact">
                    <dt>{t(locale, "listing.accessibility_notes")}</dt>
                    <dd>{data.accessibility_notes[locale]}</dd>
                  </div>
                )}

                {data.languages_spoken && data.languages_spoken.length > 0 && (
                  <div class="fact">
                    <dt>{t(locale, "listing.languages_spoken")}</dt>
                    <dd>
                      {data.languages_spoken
                        .map((code) =>
                          code === "en"
                            ? locale === "en"
                              ? "English"
                              : "Inglés"
                            : code === "es"
                              ? locale === "en"
                                ? "Spanish"
                                : "Español"
                              : code,
                        )
                        .join(", ")}
                    </dd>
                  </div>
                )}

                {data.contact &&
                  (data.contact.phone ||
                    data.contact.email ||
                    data.contact.url) && (
                    <div class="fact">
                      <dt>{t(locale, "listing.contact_label")}</dt>
                      <dd>
                        <ul role="list" class="contact-rows">
                          {data.contact.phone && (
                            <li>
                              <span class="contact-label">
                                {t(locale, "listing.contact_phone")}:
                              </span>{" "}
                              <span>{data.contact.phone}</span>
                            </li>
                          )}
                          {data.contact.email && (
                            <li>
                              <span class="contact-label">
                                {t(locale, "listing.contact_email")}:
                              </span>{" "}
                              <span>{data.contact.email}</span>
                            </li>
                          )}
                          {data.contact.url && (
                            <li>
                              <span class="contact-label">
                                {t(locale, "listing.contact_website")}:
                              </span>{" "}
                              <span>{data.contact.url}</span>
                            </li>
                          )}
                        </ul>
                      </dd>
                    </div>
                  )}
              </dl>

              <p class="verified">
                {t(locale, "listing.last_verified")}:{" "}
                <time datetime={data.last_verified_date.toISOString()}>
                  {formatDate(data.last_verified_date, locale)}
                </time>
                {isStale && (
                  <span class="stale-badge">
                    {t(locale, "listing.stale_badge")}
                  </span>
                )}
              </p>
            </article>
          </li>
        );
      })
    }
  </ul>
</BaseLayout>

<script
  is:inline
  define:vars={{
    countOne: t(locale, "list.showing_count_one"),
    countOther: t(locale, "list.showing_count_other"),
  }}
>
  (async () => {
    const filters = document.querySelector("[data-filters]");
    const listEl = document.querySelector("[data-listings]");
    const emptyEl = document.querySelector("[data-empty-state]");
    const countEl = document.querySelector("[data-results-count]");
    const clearBtn = document.querySelector("[data-clear-filters]");
    const searchRow = document.querySelector("[data-search-row]");
    const searchInput = document.querySelector("[data-search-input]");
    if (!filters || !listEl || !countEl || !clearBtn || !emptyEl) return;

    const chips = filters.querySelectorAll("[data-filter]");
    const items = listEl.querySelectorAll("li.listing");

    // searchMatches === null means "no active search" (don't filter by it).
    // A Set (possibly empty) means "only these listing IDs pass".
    const state = { region: new Set(), type: new Set(), q: "", searchMatches: null };

    const formatCount = (n) =>
      (n === 1 ? countOne : countOther).replace("{count}", String(n));

    const readURL = () => {
      const p = new URLSearchParams(window.location.search);
      state.region = new Set((p.get("region") || "").split(",").filter(Boolean));
      state.type = new Set((p.get("type") || "").split(",").filter(Boolean));
      state.q = p.get("q") || "";
    };

    const writeURL = () => {
      const p = new URLSearchParams();
      if (state.region.size) p.set("region", [...state.region].join(","));
      if (state.type.size) p.set("type", [...state.type].join(","));
      if (state.q) p.set("q", state.q);
      const qs = p.toString();
      const url =
        window.location.pathname + (qs ? "?" + qs : "") + window.location.hash;
      window.history.replaceState({}, "", url);
    };

    const matches = (li) => {
      if (state.region.size) {
        const r = li.dataset.region;
        if (!state.region.has(r)) return false;
      }
      if (state.type.size) {
        const types = (li.dataset.types || "").split(" ").filter(Boolean);
        if (!types.some((t) => state.type.has(t))) return false;
      }
      if (state.searchMatches !== null) {
        if (!state.searchMatches.has(li.dataset.listingId)) return false;
      }
      return true;
    };

    const apply = () => {
      let visible = 0;
      items.forEach((li) => {
        const ok = matches(li);
        li.hidden = !ok;
        if (ok) visible++;
      });
      countEl.textContent = formatCount(visible);
      emptyEl.hidden = visible !== 0;
      const anyActive =
        state.region.size > 0 || state.type.size > 0 || state.q.length > 0;
      clearBtn.hidden = !anyActive;
      chips.forEach((btn) => {
        const f = btn.dataset.filter;
        const v = btn.dataset.value;
        const on = state[f]?.has(v) ?? false;
        btn.setAttribute("aria-pressed", on ? "true" : "false");
      });
    };

    chips.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter;
        const v = btn.dataset.value;
        const set = state[f];
        if (!set) return;
        if (set.has(v)) set.delete(v);
        else set.add(v);
        writeURL();
        apply();
      });
    });

    clearBtn.addEventListener("click", () => {
      state.region.clear();
      state.type.clear();
      state.q = "";
      state.searchMatches = null;
      if (searchInput) searchInput.value = "";
      writeURL();
      apply();
    });

    readURL();

    // Pagefind is generated at build time; absent in `astro dev`. Load lazily
    // and reveal the search UI only if the runtime loads successfully.
    let pagefind = null;
    if (searchInput && searchRow) {
      try {
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.options({ excerptLength: 0 });
        searchRow.hidden = false;
      } catch {
        // Pagefind not available (dev server, or build without index).
        // Leave search UI hidden; chips still work.
      }
    }

    // Extract listing id from a sub-result URL like
    // "/en/list/#listing-<id>-heading". Returns null if the anchor doesn't
    // follow that pattern (e.g., the page-level result with no fragment).
    const listingIdFromUrl = (url) => {
      const hash = url.split("#")[1];
      if (!hash) return null;
      const m = hash.match(/^listing-(.+)-heading$/);
      return m ? m[1] : null;
    };

    const runSearch = async (q) => {
      state.q = q;
      if (!pagefind || !q.trim()) {
        state.searchMatches = null;
        writeURL();
        apply();
        return;
      }
      const res = await pagefind.search(q.trim());
      const ids = new Set();
      // Pull anchored sub-results from every page-level match. On our site
      // there's really only one page per locale with listings, but this is
      // defensive in case that changes.
      for (const r of res.results) {
        const data = await r.data();
        for (const sub of data.sub_results || []) {
          const id = listingIdFromUrl(sub.url);
          if (id) ids.add(id);
        }
      }
      state.searchMatches = ids;
      writeURL();
      apply();
    };

    if (searchInput) {
      if (state.q) searchInput.value = state.q;
      let timer = null;
      searchInput.addEventListener("input", (e) => {
        const v = e.target.value;
        clearTimeout(timer);
        timer = setTimeout(() => runSearch(v), 150);
      });
      if (state.q && pagefind) await runSearch(state.q);
    }

    apply();
  })();
</script>

<style>
  h1 {
    margin: 1.5rem 1rem 1rem;
    font-size: 1.75rem;
  }

  .filters {
    margin: 0 1rem 1rem;
    max-width: 64rem;
    display: grid;
    gap: 0.75rem;
  }

  .search-row {
    display: grid;
    gap: 0.25rem;
  }

  .search-label {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .search-input {
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    border: 1px solid var(--card-border-strong);
    border-radius: 6px;
    background: var(--input-bg);
    color: var(--page-text);
  }

  .filter-group {
    border: 1px solid var(--card-border);
    border-radius: 6px;
    padding: 0.5rem 0.75rem 0.75rem;
    margin: 0;
  }

  .filter-group legend {
    font-weight: 600;
    padding: 0 0.25rem;
    font-size: 0.9rem;
  }

  .chip-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .chip {
    border: 1px solid var(--card-border-strong);
    background: var(--card-bg);
    color: var(--page-text);
    padding: 0.25rem 0.75rem;
    font-size: 0.875rem;
    border-radius: 999px;
    cursor: pointer;
  }

  .chip[aria-pressed="true"] {
    background: var(--chip-on);
    color: var(--accent-fg);
    border-color: var(--chip-on);
  }

  .filter-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .clear-filters {
    border: 1px solid var(--card-border-strong);
    background: var(--card-bg);
    color: var(--page-text);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.875rem;
  }

  .results-count {
    margin: 0;
    font-size: 0.875rem;
    color: var(--page-text-muted);
  }

  .empty-state {
    margin: 1rem;
    padding: 1rem;
    background: var(--bg-muted);
    border-radius: 6px;
    color: var(--page-text-muted);
    max-width: 64rem;
  }

  .listings {
    list-style: none;
    padding: 0;
    margin: 0 1rem;
    display: grid;
    gap: 1rem;
    max-width: 64rem;
  }

  .listing {
    border: 1px solid var(--card-border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    background: var(--card-bg);
  }

  .listing-stale {
    opacity: 0.75;
    background: var(--stale-bg);
  }

  .listing-header h2 {
    margin: 0 0 0.125rem;
    font-size: 1.25rem;
  }

  .location-name {
    margin: 0 0 0.75rem;
    color: var(--page-text-muted);
    font-size: 0.9rem;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.8rem;
    border-radius: 999px;
    color: var(--accent-fg);
  }

  .tag-type {
    background: var(--tag-type);
  }

  .tag-category {
    background: var(--tag-category);
  }

  .tag-season {
    background: var(--tag-season);
  }

  .contact-rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.125rem;
  }

  .contact-label {
    font-weight: 500;
  }

  .description {
    margin: 0.5rem 0 0.75rem;
    line-height: 1.5;
  }

  .listing-facts {
    margin: 0.5rem 0 0.75rem;
    display: grid;
    gap: 0.5rem;
  }

  .fact {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.75rem;
  }

  .fact dt {
    font-weight: 600;
  }

  .fact dd {
    margin: 0;
  }

  .hours-rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.125rem;
  }

  .hours-rows li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0.5rem;
  }

  .hours-label {
    font-weight: 500;
  }

  .verified {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--page-text-muted);
  }

  .stale-badge {
    margin-left: 0.5rem;
    padding: 0.125rem 0.5rem;
    background: var(--stale-fg);
    color: var(--accent-fg);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  @media (max-width: 540px) {
    .fact {
      grid-template-columns: 1fr;
      gap: 0.125rem;
    }
  }
</style>
