{
  "name": "mutual-aid-phoenix",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm build:admin && astro dev",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build": "pnpm build:admin && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "ship": "pnpm build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "astro": "^6.1.7",
    "maplibre-gl": "^5.23.0",
    "pmtiles": "^4.4.1",
    "protomaps-themes-base": "^4.5.0",
    "wrangler": "^4.83.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "pagefind": "^1.5.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "^7.3.2"
  }
}